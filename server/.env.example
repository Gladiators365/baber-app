# Barber APP Environment Variables
# Copy this to .env and fill in your values

# Server
PORT=3001

# Twilio (leave blank to use stubbed SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Barber defaults
DEFAULT_BARBER_NAME=Mark
DEFAULT_CUT_DURATION_MINUTES=45
DEFAULT_PRICE=35.00

# Retention engine
RETENTION_CRON=0 10 * * *
REMINDER_COOLDOWN_DAYS=3
